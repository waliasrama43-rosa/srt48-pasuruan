# ================================================================
# Environment Variables — Salin file ini menjadi .env
# dan isi dengan nilai yang sebenarnya.
# JANGAN commit file .env ke repository.
# ================================================================

# Server
PORT=5000
NODE_ENV=development

# Supabase (dapatkan dari: https://supabase.com/dashboard → project → settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# JWT — ganti dengan string random yang panjang dan aman
JWT_SECRET=ganti_dengan_string_random_minimal_32_karakter

# Telegram Bot (dapatkan dari @BotFather di Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:3000

# Super Admin — untuk seed pertama kali (opsional)
SUPER_ADMIN_EMAIL=superadmin@saas.com
SUPER_ADMIN_PASSWORD=ganti_password_kuat
